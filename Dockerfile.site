# Sailfish gateway/site image — the hosted service + local appliance web layer.
# (The serving ENGINE runs separately: container/llamacpp or container/ for vLLM.
#  This image is the FastAPI gateway + static site + control API.)
FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 PYTHONDONTWRITEBYTECODE=1 PYTHONPATH=/app
WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app/ ./app/
COPY site/ ./site/

# Cloud Run injects PORT (8080). Local appliance uses 22343 via SAILFISH_PORT.
ENV SAILFISH_PORT=8080
EXPOSE 8080
CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-${SAILFISH_PORT}}"]
